aweed with your sushi rice approximately 1cm high.<\/p><\/li><li><p>Add your ingredients in a line on top of the rice in the centre. You can choose any combination of ingredients that compliment each other well. We went for salmon, salad and mayonnaise for this one.<\/p><\/li><li><p>Now for the fun bit. Using the wooden rolling mat, start rolling up the ingredients away from you, while keeping the roll tight. The moisture from the rice will help it stick together.<\/p><\/li><li><p>You can then cut your roll into 6-8 pieces and serve with some soy sauce, wasabi, sushi ginger and cup of sencha green tea.<\/p><\/li><\/ol>","align":"left","text_color":"#000000","typography_typography":"custom","typography_font_family":"Cabin","typography_font_size":{"unit":"rem","size":"1.1"},"typography_line_height":{"unit":"em","size":"1.7"}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":"","elType":"column"},{"id":"5f09891a","settings":{"_column_size":"50","_inline_size":"","_inline_size_tablet":"100","content_position":"top","padding":{"unit":"%","top":"","right":"","bottom":"","left":"","isLinked":"1"},"padding_tablet":{"unit":"em","top":"1","right":"1","bottom":"1","left":"1","isLinked":"1"}},"elements":[{"id":"48afddd9","settings":{"image":{"url":"http:\/\/sitefacilitado.com.br\/wp-content\/uploads\/2020\/04\/filippo-faruffini-749620-unsplash-e1535466272472-1.jpg","id":"2808"},"image_border_radius":{"unit":"px","top":"10","right":"0","bottom":"10","left":"0","isLinked":""},"image_box_shadow_box_shadow_type":"yes","image_box_shadow_box_shadow":{"horizontal":"7","vertical":"7","blur":"0","spread":"0","color":"#000000"},"caption_align":"center","_border_width":{"unit":"px","top":"5","right":"5","bottom":"5","left":"5","isLinked":"1"},"_border_color":"#ffffff","_border_radius":{"unit":"px","top":"15","right":"0","bottom":"10","left":"0","isLinked":""},"_box_shadow_box_shadow_type":"yes","_box_shadow_box_shadow":{"horizontal":"7","vertical":"4"